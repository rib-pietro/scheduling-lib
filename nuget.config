<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="local-scheduling-lib" value="./local-packages" />
    <add key="github-scheduling-lib" value="https://nuget.pkg.github.com/rib-pietro/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- SchedulingLib packages are resolved from the local folder first, then GitHub Packages -->
    <packageSource key="local-scheduling-lib">
      <package pattern="SchedulingLib.*" />
    </packageSource>
    <packageSource key="github-scheduling-lib">
      <package pattern="SchedulingLib.*" />
    </packageSource>
    <!-- Everything else comes from nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
